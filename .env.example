# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/fiperde
MONGODB_TEST_URI=mongodb://mongodb-test:27017/fiperde-test

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Optional: Database name override
DB_NAME=fiperde
DB_TEST_NAME=fiperde-test

# MongoDB Authentication
MONGO_ROOT_USERNAME=your_mongo_username
MONGO_ROOT_PASSWORD=your_strong_password_here
